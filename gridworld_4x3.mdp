TRANSITION: R3C1 Right R3C1 0.1
TRANSITION: R3C1 Right R2C1 0.1

# ---- R3C2 ----
# Up: intended=R3C2(boundary), slip-left=R3C1, slip-right=R3C3
TRANSITION: R3C2 Up R3C2 0.8
TRANSITION: R3C2 Up R3C1 0.1
TRANSITION: R3C2 Up R3C3 0.1

# Down: intended=R2C2(WALL→stay), slip-left=R3C3, slip-right=R3C1
TRANSITION: R3C2 Down R3C2 0.8
TRANSITION: R3C2 Down R3C3 0.1
TRANSITION: R3C2 Down R3C1 0.1

# Left: intended=R3C1, slip-left=R3C2(boundary), slip-right=R2C2(WALL→stay)
TRANSITION: R3C2 Left R3C1 0.8
TRANSITION: R3C2 Left R3C2 0.2

# Right: intended=R3C3, slip-left=R2C2(WALL→stay), slip-right=R3C2(boundary)
TRANSITION: R3C2 Right R3C3 0.8
TRANSITION: R3C2 Right R3C2 0.2

# ---- R3C3 ----
# Up: intended=R3C3(boundary), slip-left=R3C2, slip-right=R3C4
TRANSITION: R3C3 Up R3C3 0.8
TRANSITION: R3C3 Up R3C2 0.1
TRANSITION: R3C3 Up R3C4 0.1

# Down: intended=R2C3, slip-left=R3C4, slip-right=R3C2
TRANSITION: R3C3 Down R2C3 0.8
TRANSITION: R3C3 Down R3C4 0.1
TRANSITION: R3C3 Down R3C2 0.1

# Left: intended=R3C2, slip-left=R2C3, slip-right=R3C3(boundary)
TRANSITION: R3C3 Left R3C2 0.8
TRANSITION: R3C3 Left R2C3 0.1
TRANSITION: R3C3 Left R3C3 0.1

# Right: intended=R3C4, slip-left=R3C3(boundary), slip-right=R2C3
TRANSITION: R3C3 Right R3C4 0.8
TRANSITION: R3C3 Right R3C3 0.1
TRANSITION: R3C3 Right R2C3 0.1

# ---- R3C4 = GOAL (absorbing) ----
TRANSITION: R3C4 Up R3C4 1.0
TRANSITION: R3C4 Down R3C4 1.0
TRANSITION: R3C4 Left R3C4 1.0
TRANSITION: R3C4 Right R3C4 1.0

