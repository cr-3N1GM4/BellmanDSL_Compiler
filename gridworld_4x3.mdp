TRANSITION: R3C1 Down R3C2 0.1
TRANSITION: R3C1 Down R3C1 0.1

# Left: intended=R3C1(boundary), slip-left=R2C1, slip-right=R3C1(boundary)
TRANSITION: R3C1 Left R3C1 0.9
TRANSITION: R3C1 Left R2C1 0.1

# Right: intended=R3C2, slip-left=R3C1(boundary), slip-right=R2C1
